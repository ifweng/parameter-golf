# Sourceable cloud run environment for the PR1855 Exp01/Exp03 lane.
#
# Usage from /workspace/parameter-golf:
#   source frontier/lanes/pr1855_exp01_awqlite_asymlogit/configs/cloud_run.env
#
# Select a run without editing this file:
#   PG_EXPERIMENT=baseline2101 source frontier/lanes/pr1855_exp01_awqlite_asymlogit/configs/cloud_run.env
#   PG_EXPERIMENT=exp03_lossgated_ttt source frontier/lanes/pr1855_exp01_awqlite_asymlogit/configs/cloud_run.env
#
# Supported PG_EXPERIMENT values:
#   baseline2101
#   exp02_2060
#   exp02_tttlocal080_evalonly
#   exp03_lossgated_ttt
#   exp03_lossgated_ttt_evalonly
#   exp03_2060_lossgated_ttt

export WORKSPACE_ROOT="${WORKSPACE_ROOT:-/workspace}"
export REPO_ROOT="${REPO_ROOT:-$WORKSPACE_ROOT/parameter-golf}"
export LANE_NAME="pr1855_exp01_awqlite_asymlogit"
export LANE_DIR="$REPO_ROOT/frontier/lanes/$LANE_NAME"

_PG_USER_RUN_ROOT_SET="${RUN_ROOT+x}"
_PG_USER_ARTIFACT_ROOT_SET="${ARTIFACT_ROOT+x}"

# Bootstrap writes this file after downloading CaseOps data. Source it if
# present, then override RUN_ROOT below unless the user set RUN_ROOT already.
if [ -f "$WORKSPACE_ROOT/pr1855_exp01_data.env" ]; then
  # shellcheck source=/dev/null
  . "$WORKSPACE_ROOT/pr1855_exp01_data.env"
fi

export CASEOPS_DATA_PATH="${CASEOPS_DATA_PATH:-$WORKSPACE_ROOT/data/datasets/fineweb10B_sp8192_caseops/datasets/datasets/fineweb10B_sp8192_lossless_caps_caseops_v1_reserved}"
export TOKENIZER_PATH="${TOKENIZER_PATH:-$WORKSPACE_ROOT/data/datasets/fineweb10B_sp8192_caseops/datasets/tokenizers/fineweb_8192_bpe_lossless_caps_caseops_v1_reserved.model}"

if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
  export PYTHON="${PYTHON:-$REPO_ROOT/.venv/bin/python}"
else
  export PYTHON="${PYTHON:-python3}"
fi

if [ -x "$REPO_ROOT/.venv/bin/torchrun" ]; then
  export TORCHRUN="${TORCHRUN:-$REPO_ROOT/.venv/bin/torchrun}"
else
  export TORCHRUN="${TORCHRUN:-torchrun}"
fi

export NPROC_PER_NODE="${NPROC_PER_NODE:-8}"
export SEEDS="${SEEDS:-42}"
export COMPRESSOR="${COMPRESSOR:-pergroup}"
export PG_EXPERIMENT="${PG_EXPERIMENT:-exp03_lossgated_ttt}"

case "$PG_EXPERIMENT" in
  baseline2101)
    export CONFIG_PATH="$LANE_DIR/configs/pr1855_exp01.env"
    _PG_RUN_DEFAULT="$WORKSPACE_ROOT/runs/pr1855_exp01_seed42"
    export TTT_EVAL_ONLY="0"
    ;;
  exp02_2060)
    export CONFIG_PATH="$LANE_DIR/configs/exp02_2060_retune.env"
    _PG_RUN_DEFAULT="$WORKSPACE_ROOT/runs/pr1855_exp02_2060retune_seed42"
    export TTT_EVAL_ONLY="0"
    ;;
  exp02_tttlocal080_evalonly)
    export CONFIG_PATH="$LANE_DIR/configs/exp02_tttlocal080_only.env"
    _PG_RUN_DEFAULT="$WORKSPACE_ROOT/runs/pr1855_exp02_tttlocal080_seed42"
    export TTT_EVAL_ONLY="1"
    if [ -z "$_PG_USER_ARTIFACT_ROOT_SET" ]; then
      export ARTIFACT_ROOT="$WORKSPACE_ROOT/runs/pr1855_exp01_seed42"
    fi
    ;;
  exp03_lossgated_ttt)
    export CONFIG_PATH="$LANE_DIR/configs/exp03_lossgated_ttt.env"
    _PG_RUN_DEFAULT="$WORKSPACE_ROOT/runs/pr1855_exp03_lossgated_ttt_seed42"
    export TTT_EVAL_ONLY="0"
    ;;
  exp03_lossgated_ttt_evalonly)
    export CONFIG_PATH="$LANE_DIR/configs/exp03_lossgated_ttt.env"
    _PG_RUN_DEFAULT="$WORKSPACE_ROOT/runs/pr1855_exp03_lossgated_ttt_evalonly_seed42"
    export TTT_EVAL_ONLY="1"
    if [ -z "$_PG_USER_ARTIFACT_ROOT_SET" ]; then
      export ARTIFACT_ROOT="$WORKSPACE_ROOT/runs/pr1855_exp01_seed42"
    fi
    ;;
  exp03_2060_lossgated_ttt)
    export CONFIG_PATH="$LANE_DIR/configs/exp03_2060_lossgated_ttt.env"
    _PG_RUN_DEFAULT="$WORKSPACE_ROOT/runs/pr1855_exp03_2060_lossgated_ttt_seed42"
    export TTT_EVAL_ONLY="0"
    ;;
  *)
    echo "Unknown PG_EXPERIMENT='$PG_EXPERIMENT'" >&2
    echo "Supported: baseline2101 exp02_2060 exp02_tttlocal080_evalonly exp03_lossgated_ttt exp03_lossgated_ttt_evalonly exp03_2060_lossgated_ttt" >&2
    return 2 2>/dev/null || exit 2
    ;;
esac

if [ -z "$_PG_USER_RUN_ROOT_SET" ]; then
  export RUN_ROOT="$_PG_RUN_DEFAULT"
fi

export PG_RUN_COMMAND="NPROC_PER_NODE=\"$NPROC_PER_NODE\" SEEDS=\"$SEEDS\" bash frontier/lanes/$LANE_NAME/run_8xh100.sh"

echo "PG_EXPERIMENT=$PG_EXPERIMENT"
echo "CONFIG_PATH=$CONFIG_PATH"
echo "RUN_ROOT=$RUN_ROOT"
echo "ARTIFACT_ROOT=${ARTIFACT_ROOT:-<runner defaults to RUN_ROOT>}"
echo "TTT_EVAL_ONLY=$TTT_EVAL_ONLY"
echo "CASEOPS_DATA_PATH=$CASEOPS_DATA_PATH"
echo "TOKENIZER_PATH=$TOKENIZER_PATH"
echo "Run with:"
echo "  $PG_RUN_COMMAND"
