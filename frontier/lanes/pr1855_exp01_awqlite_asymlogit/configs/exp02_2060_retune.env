# Exp02: #2101 base + #2060 five-knob retune.
#
# This is the first real improvement attempt beyond reproducing #2101.
# It keeps the #2101 source and compliance profile, then applies the
# low-byte env-only retune that PR #2060 reported as a paired 3-seed win.

LANE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=/dev/null
source "$LANE_DIR/configs/pr1855_exp01.env"

# Force these values after sourcing the base config. Do not use ${VAR:-...}
# here: the base config already sets defaults.
export MATRIX_LR="0.028"
export LQER_RANK="2"
export LQER_ASYM_GROUP="32"
export LQER_TOP_K="4"
export TTT_LOCAL_LR_MULT="0.80"

# Keep #2101 phasing for the first A/B so the comparison isolates the five
# knobs above. If this wins, test prefix-doc variants separately.
export PHASED_TTT_PREFIX_DOCS="2500"
export PHASED_TTT_NUM_PHASES="3"
