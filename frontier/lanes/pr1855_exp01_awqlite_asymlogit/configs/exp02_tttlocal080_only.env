# Exp02 cheap eval-only probe: #2101 base with hotter local TTT only.
#
# Use with TTT_EVAL_ONLY=1 and ARTIFACT_ROOT pointing at an existing #2101
# artifact run. This lets us test the #2060 TTT_LOCAL_LR_MULT part without
# retraining or re-quantizing.

LANE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=/dev/null
source "$LANE_DIR/configs/pr1855_exp01.env"

export TTT_LOCAL_LR_MULT="0.80"
