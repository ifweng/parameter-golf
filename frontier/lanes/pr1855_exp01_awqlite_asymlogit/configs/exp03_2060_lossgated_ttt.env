# Exp03b: #2060 retune plus novel score-first hard-example TTT gate.
#
# Use only after exp03_lossgated_ttt.env proves the TTT gate is neutral or
# positive. This stacks the novel TTT update gate on the strongest config-only
# retune we have.

LANE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=/dev/null
source "$LANE_DIR/configs/exp02_2060_retune.env"

export TTT_LOSS_GATE_ENABLED="1"
export TTT_LOSS_GATE_Z="-0.25"
export TTT_LOSS_GATE_MIN_FRAC="0.35"
export TTT_LOSS_GATE_WARMUP_CHUNKS="1"
