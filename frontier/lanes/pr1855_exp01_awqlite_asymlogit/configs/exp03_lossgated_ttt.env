# Exp03: novel score-first hard-example TTT update gate.
#
# This is our first non-copycat method. It keeps the #2101 base and changes
# only the legal post-score LoRA update rule: after each chunk is scored and
# accumulated into BPB, update LoRA only on the higher-loss documents in that
# batch. The hypothesis is that easy chunks add noisy/overfit TTT gradients,
# while hard chunks contain the adaptation signal we actually want.

LANE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=/dev/null
source "$LANE_DIR/configs/pr1855_exp01.env"

export TTT_LOSS_GATE_ENABLED="1"
export TTT_LOSS_GATE_Z="-0.25"
export TTT_LOSS_GATE_MIN_FRAC="0.35"
export TTT_LOSS_GATE_WARMUP_CHUNKS="1"
