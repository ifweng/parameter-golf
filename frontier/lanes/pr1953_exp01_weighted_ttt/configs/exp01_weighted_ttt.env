# PR #1953 Exp01: continuous loss-weighted local TTT updates.
# Source with:
#   source frontier/lanes/pr1953_exp01_weighted_ttt/configs/exp01_weighted_ttt.env

LANE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_ROOT="$(cd "$LANE_DIR/../../.." && pwd)"

# Start from the frozen PR #1953 reproduction config, then add only the
# adaptive local-TTT update weighting knobs.
# shellcheck source=/dev/null
source "$REPO_ROOT/frontier/lanes/pr1953/configs/pr1953.env"

export TTT_LOSS_WEIGHTED_ENABLED="${TTT_LOSS_WEIGHTED_ENABLED:-1}"
export TTT_LOSS_WEIGHT_ALPHA="${TTT_LOSS_WEIGHT_ALPHA:-0.5}"
export TTT_LOSS_WEIGHT_MIN="${TTT_LOSS_WEIGHT_MIN:-0.5}"
export TTT_LOSS_WEIGHT_MAX="${TTT_LOSS_WEIGHT_MAX:-1.75}"
export TTT_LOSS_WEIGHT_EMA="${TTT_LOSS_WEIGHT_EMA:-0.98}"
