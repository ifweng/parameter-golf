# PR #2014 reproduction environment.
# Source with:
#   source frontier/lanes/pr2014/configs/pr2014.env
#
# Defaults are override-friendly so smoke commands can set variables before
# this file is sourced by run_8xh100.sh.

export NCCL_NET="${NCCL_NET:-Socket}"

export VOCAB_SIZE="${VOCAB_SIZE:-8192}"
export CASEOPS_ENABLED="${CASEOPS_ENABLED:-1}"

export ITERATIONS="${ITERATIONS:-20000}"
export MAX_WALLCLOCK_SECONDS="${MAX_WALLCLOCK_SECONDS:-600}"
export WARMUP_STEPS="${WARMUP_STEPS:-20}"
export VAL_LOSS_EVERY="${VAL_LOSS_EVERY:-0}"

export EVAL_INCLUDE_TAIL="${EVAL_INCLUDE_TAIL:-1}"
export TRAIN_SEQ_LEN="${TRAIN_SEQ_LEN:-3072}"
export ROPE_TRAIN_SEQ_LEN="${ROPE_TRAIN_SEQ_LEN:-3072}"
export TRAIN_SEQ_SCHEDULE="${TRAIN_SEQ_SCHEDULE:-1024@0.100,2048@0.700,3072@1.000}"
export TRAIN_SEQ_SCHEDULE_MODE="${TRAIN_SEQ_SCHEDULE_MODE:-wallclock}"
export SEQ_CHANGE_WARMUP_STEPS="${SEQ_CHANGE_WARMUP_STEPS:-32}"
export EVAL_SEQ_LEN="${EVAL_SEQ_LEN:-3072}"
export EVAL_STRIDE="${EVAL_STRIDE:-1536}"

export PHASED_TTT_ENABLED="${PHASED_TTT_ENABLED:-1}"
export PHASED_TTT_PREFIX_DOCS="${PHASED_TTT_PREFIX_DOCS:-2500}"
export PHASED_TTT_NUM_PHASES="${PHASED_TTT_NUM_PHASES:-1}"

export TTT_ENABLED="${TTT_ENABLED:-1}"
export TTT_EVAL_SEQ_LEN="${TTT_EVAL_SEQ_LEN:-3072}"
export TTT_BATCH_SIZE="${TTT_BATCH_SIZE:-24}"
export TTT_CHUNK_SIZE="${TTT_CHUNK_SIZE:-48}"
export TTT_SHORT_SCORE_FIRST_ENABLED="${TTT_SHORT_SCORE_FIRST_ENABLED:-1}"
export TTT_SHORT_DOC_LEN="${TTT_SHORT_DOC_LEN:-2000}"
export TTT_SHORT_CHUNK_SIZE="${TTT_SHORT_CHUNK_SIZE:-24}"
export TTT_SHORT_SCORE_FIRST_STEPS="${TTT_SHORT_SCORE_FIRST_STEPS:-256:8,2000:24}"
export TTT_LORA_RANK="${TTT_LORA_RANK:-80}"
export TTT_LORA_LR="${TTT_LORA_LR:-0.0001}"
export TTT_LOCAL_LR_MULT="${TTT_LOCAL_LR_MULT:-0.75}"
export TTT_MASK="${TTT_MASK:-no_qv}"
export TTT_Q_LORA="${TTT_Q_LORA:-0}"
export TTT_V_LORA="${TTT_V_LORA:-0}"
export TTT_WEIGHT_DECAY="${TTT_WEIGHT_DECAY:-0.5}"
export TTT_BETA2="${TTT_BETA2:-0.99}"
export GLOBAL_TTT_MOMENTUM="${GLOBAL_TTT_MOMENTUM:-0.9}"

export EMBED_BITS="${EMBED_BITS:-7}"
export MATRIX_LR="${MATRIX_LR:-0.026}"
export MIN_LR="${MIN_LR:-0.10}"
export MLP_CLIP_SIGMAS="${MLP_CLIP_SIGMAS:-11.5}"
export MATRIX_CLIP_SIGMAS="${MATRIX_CLIP_SIGMAS:-12.85}"
export ATTN_CLIP_SIGMAS="${ATTN_CLIP_SIGMAS:-13.0}"
export EMBED_CLIP_SIGMAS="${EMBED_CLIP_SIGMAS:-14.0}"
export GRAD_CLIP_NORM="${GRAD_CLIP_NORM:-0.3}"
export WARMDOWN_FRAC="${WARMDOWN_FRAC:-0.85}"
export BETA2="${BETA2:-0.99}"
export MUON_BACKEND_STEPS="${MUON_BACKEND_STEPS:-5}"
export QK_GAIN_INIT="${QK_GAIN_INIT:-5.25}"

export GPTQ_RESERVE_SECONDS="${GPTQ_RESERVE_SECONDS:-4.0}"
export GPTQ_CALIBRATION_BATCHES="${GPTQ_CALIBRATION_BATCHES:-16}"

export GATED_ATTN_QUANT_GATE="${GATED_ATTN_QUANT_GATE:-1}"
export SPARSE_ATTN_GATE_ENABLED="${SPARSE_ATTN_GATE_ENABLED:-1}"
export SPARSE_ATTN_GATE_INIT_STD="${SPARSE_ATTN_GATE_INIT_STD:-0.0}"
export SPARSE_ATTN_GATE_SCALE="${SPARSE_ATTN_GATE_SCALE:-0.5}"
export GATE_WINDOW="${GATE_WINDOW:-12}"
export SMEAR_GATE_ENABLED="${SMEAR_GATE_ENABLED:-1}"

export LQER_ENABLED="${LQER_ENABLED:-1}"
export LQER_ASYM_ENABLED="${LQER_ASYM_ENABLED:-1}"
export LQER_RANK="${LQER_RANK:-4}"
export LQER_FACTOR_BITS="${LQER_FACTOR_BITS:-4}"
export LQER_ASYM_GROUP="${LQER_ASYM_GROUP:-64}"
export LQER_TOP_K="${LQER_TOP_K:-3}"

export AWQ_LITE_ENABLED="${AWQ_LITE_ENABLED:-1}"
export AWQ_LITE_BITS="${AWQ_LITE_BITS:-8}"
export AWQ_LITE_GROUP_TOP_K="${AWQ_LITE_GROUP_TOP_K:-1}"
export AWQ_LITE_GROUP_SIZE="${AWQ_LITE_GROUP_SIZE:-64}"
export ASYM_LOGIT_RESCALE="${ASYM_LOGIT_RESCALE:-1}"

export FUSED_CE_ENABLED="${FUSED_CE_ENABLED:-1}"
export COMPRESSOR="${COMPRESSOR:-pergroup}"
