# PR #2014 exp01 overlay.
# Source with:
#   source frontier/lanes/pr2014_exp01_slope03_rchgptq/configs/exp01.env
#
# This intentionally sources the frozen PR #2014 reproduction config first,
# then applies only the two exp01 deltas.

_EXP01_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$_EXP01_CONFIG_DIR/../../pr2014/configs/pr2014.env"
unset _EXP01_CONFIG_DIR

export LEAKY_RELU_SQ_SLOPE="${LEAKY_RELU_SQ_SLOPE:-0.3}"
export GPTQ_HINV_MODE="${GPTQ_HINV_MODE:-reverse_cholesky}"
