# PR #2014 exp01 stronger eval-time rescue overlay.
# Use only if fasteval2816 still exceeds the 600s eval budget.

_EXP01_FASTEVAL_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$_EXP01_FASTEVAL_CONFIG_DIR/exp01.env"
unset _EXP01_FASTEVAL_CONFIG_DIR

# 2560-token eval/TTT windows are used by several late-frontier records and
# provide a larger timing margin than the #2014 3072-token path.
export EVAL_SEQ_LEN=2560
export EVAL_STRIDE=1280
export TTT_EVAL_SEQ_LEN=2560
