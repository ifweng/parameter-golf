# PR #2014 exp01 eval-time rescue overlay.
# Use when the normal 3072-token TTT eval is slightly over the 600s limit.

_EXP01_FASTEVAL_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$_EXP01_FASTEVAL_CONFIG_DIR/exp01.env"
unset _EXP01_FASTEVAL_CONFIG_DIR

# Keep the trained model unchanged and only shorten evaluation windows.
# This preserves score-first TTT legality while reducing per-chunk attention cost.
export EVAL_SEQ_LEN=2816
export EVAL_STRIDE=1408
export TTT_EVAL_SEQ_LEN=2816
