# PR #2014 exp01 size-safe overlay.
# Use only when the normal exp01 artifact is slightly over the 16,000,000 byte cap.

_EXP01_FIT_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$_EXP01_FIT_CONFIG_DIR/exp01.env"
unset _EXP01_FIT_CONFIG_DIR

# The upstream #2014 stack protects one high-saliency group at AWQ-lite int8.
# Removing that single protected group saves a few KB while preserving the
# rest of GPTQ + LQER. This is safer than reducing LQER rank/top-k first.
export AWQ_LITE_GROUP_TOP_K=0
