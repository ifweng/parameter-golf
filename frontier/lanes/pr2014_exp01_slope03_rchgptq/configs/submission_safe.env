# PR #2014 exp01 combined safety overlay.
# Use when the normal exp01 run is both slightly over size and slightly over eval time.

_EXP01_SAFE_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$_EXP01_SAFE_CONFIG_DIR/fit16mb.env"
unset _EXP01_SAFE_CONFIG_DIR

# Start with the least disruptive runtime rescue. If this remains over 600s,
# override TTT_EVAL_SEQ_LEN/EVAL_SEQ_LEN/EVAL_STRIDE to 2560/2560/1280 at launch.
export EVAL_SEQ_LEN=2816
export EVAL_STRIDE=1408
export TTT_EVAL_SEQ_LEN=2816
