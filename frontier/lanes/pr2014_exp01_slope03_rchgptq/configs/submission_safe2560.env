# PR #2014 exp01 combined safety overlay with stronger eval-time margin.
# Use if submission_safe.env still exceeds the 600s eval budget.

_EXP01_SAFE_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$_EXP01_SAFE_CONFIG_DIR/fit16mb.env"
unset _EXP01_SAFE_CONFIG_DIR

export EVAL_SEQ_LEN=2560
export EVAL_STRIDE=1280
export TTT_EVAL_SEQ_LEN=2560
